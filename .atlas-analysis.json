  "keyFeatures": [
    "Multi-tenant WhatsApp API with Baileys and Business API support",
    "Integration with 7+ chatbot platforms (Typebot, Chatwoot, Dify, OpenAI, etc.)",
    "Event streaming via RabbitMQ, Kafka, SQS, WebSocket, and Pusher",
    "S3/MinIO media storage with automatic file management",
    "Multi-database support (PostgreSQL, MySQL) with Prisma ORM",
    "QR code authentication and connection management",
    "Comprehensive webhook system with retry logic",
    "RESTful API for message, chat, group, and contact operations"
  ],
  "publicApiSurface": [
    "POST /instance/create - Create new WhatsApp instance",
    "GET /instance/fetchInstances - List all instances",
    "POST /instance/connect/:instanceName - Connect instance",
    "DELETE /instance/delete/:instanceName - Delete instance",
    "POST /message/sendText/:instanceName - Send text message",
    "POST /message/sendMedia/:instanceName - Send media message",
    "POST /message/sendAudio/:instanceName - Send audio message",
    "POST /message/sendLocation/:instanceName - Send location",
    "POST /message/sendContact/:instanceName - Send contact",
    "GET /chat/findChats/:instanceName - Find chats",
    "POST /chat/archiveChat/:instanceName - Archive chat",
    "POST /group/create/:instanceName - Create group",
    "GET /group/findGroupInfo/:instanceName - Get group info",
    "POST /group/updateParticipant/:instanceName - Update group participant",
    "GET /chat/findContacts/:instanceName - Find contacts",
    "POST /label/create/:instanceName - Create label",
    "POST /settings/updateProfileName/:instanceName - Update profile",
    "POST /proxy/set/:instanceName - Configure proxy",
    "POST /webhook/set/:instanceName - Configure webhook",
    "POST /typebot/create/:instanceName - Create Typebot integration",
    "POST /chatwoot/create/:instanceName - Create Chatwoot integration",
    "POST /openai/create/:instanceName - Create OpenAI integration"
  ]
}
